{
  "name": "storybook-poc",
  "version": "1.0.0",
  "description": "POC for Storybook with reusable component packages",
  "private": true,
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o build/storybook",
    "build:packages": "npm run build --workspace=packages/ui-components",
    "build": "npm run build:packages && npm run build-storybook",
    "dev": "npm run storybook",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build:packages"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/addon-links": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-webpack5": "^8.6.18",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "storybook": "^8.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "storybook",
    "react",
    "components",
    "ui",
    "poc"
  ],
  "author": "",
  "license": "MIT"
}
