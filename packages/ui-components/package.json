{
  "name": "@storybook-poc/ui-components",
  "version": "0.1.0",
  "description": "Reusable UI components for Storybook POC",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc",
    "build:esm": "tsc -m esnext --outDir dist/esm",
    "dev": "tsc --watch"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "storybook"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
