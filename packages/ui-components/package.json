{
  "name": "@bv-ArulkumarK/ui-components",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "0.1.0",
  "description": "Reusable UI components for Storybook POC",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc",
    "build:esm": "tsc -m esnext --outDir dist/esm",
    "dev": "tsc --watch"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "storybook"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@bv-ArulkumarK/ui-components": "git+ssh://git@github.com/bv-ArulkumarK/ui-components.git#v1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
